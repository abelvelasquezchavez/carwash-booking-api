# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (MySQL 8) ──────────────────────────────────────────────────────
# Matches the credentials defined in docker-compose.yml
DATABASE_URL="mysql://carwash:carwash@localhost:3306/carwash"

# ── Auth (JWT) ──────────────────────────────────────────────────────────────
# Use a long, random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# ── Business hours (24h, used by the availability engine) ───────────────────
# Opening / closing hour of the car wash, as integers (0-24).
BUSINESS_OPEN=8
BUSINESS_CLOSE=18
